// Generator: prisma-client-js

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

model Artist {
  id         String    @id @default(uuid())
  name       String    @unique
  products   Product[]
  images     Image[]   // New direct relation
  created_at DateTime  @default(now())

  @@map("artists")
}

model Product {
  id             String   @id @default(uuid())
  artist_id      String
  artist         Artist   @relation(fields: [artist_id], references: [id], onDelete: Cascade)
  title          String
  images         Image[]
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([artist_id])
  @@index([title])
  @@index([created_at])
  @@map("products")
}

model Image {
  id         String   @id @default(uuid())
  product_id String?  // Optional now
  product    Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  artist_id  String?  // New field
  artist     Artist?  @relation(fields: [artist_id], references: [id], onDelete: SetNull)
  url        String
  alt_text   String?
  mime_type  String?
  size_bytes Int?
  width      Int?
  height     Int?
  created_at DateTime @default(now())

  @@index([product_id])
  @@index([artist_id])
  @@map("images")
}
